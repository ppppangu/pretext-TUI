{
  "name": "pretext-tui",
  "version": "0.1.0-alpha.0",
  "description": "Host-neutral terminal-cell text layout primitives for TUIs, CLIs, logs, transcripts, and editor panes",
  "keywords": [
    "tui",
    "terminal",
    "terminal-ui",
    "terminal-layout",
    "line-breaking",
    "text-layout",
    "cli",
    "log-viewer",
    "transcript",
    "editor-pane",
    "unicode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppppangu/pretext-TUI.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./terminal": {
      "types": "./dist/terminal.d.ts",
      "import": "./dist/terminal.js",
      "default": "./dist/terminal.js"
    },
    "./terminal-rich-inline": {
      "types": "./dist/terminal-rich-inline.d.ts",
      "import": "./dist/terminal-rich-inline.js",
      "default": "./dist/terminal-rich-inline.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/terminal.js",
    "dist/terminal.d.ts",
    "dist/terminal-rich-inline.js",
    "dist/terminal-rich-inline.d.ts",
    "dist/internal"
  ],
  "scripts": {
    "api-snapshot-check": "bun run build:package && bun run scripts/api-snapshot-check.ts",
    "build:package": "bun run scripts/build-package.ts",
    "benchmark-check:tui": "bun run scripts/tui-benchmark-check.ts",
    "benchmark:competitive:tui": "bun run scripts/competitive-tui-benchmark.ts",
    "benchmark:evidence:tui": "bun run scripts/competitive-tui-benchmark.ts --report-dir docs/evidence/benchmark-reports --package-script benchmark:evidence:tui",
    "benchmark:evidence-summary:tui": "bun run scripts/tui-benchmark-evidence-summary.ts",
    "check": "bun run typecheck:tui && bun run typecheck:tui-validation && bun run tui-static-gate && oxlint --type-aware src",
    "demo:compare:tui": "bun run scripts/terminal-feel-demo.ts",
    "generate:bidi-data": "bun run scripts/generate-bidi-data.ts",
    "package-smoke-test": "bun run scripts/package-smoke-test.ts",
    "prepack": "bun run build:package",
    "memory-budget-check:tui": "bun run scripts/tui-memory-budget-check.ts",
    "prepublishOnly": "bun run release-gate:tui",
    "release-gate:tui": "bun run check && bun run test:tui && bun run tui-oracle-check && bun run tui-corpus-check && bun run tui-fuzz --seed=ci --cases=2000 && bun run benchmark-check:tui && bun run memory-budget-check:tui && bun run terminal-demo-check && bun run terminal-feel-demo-check && bun run api-snapshot-check && bun run package-smoke-test",
    "test:tui": "bun test src/terminal-core.test.ts src/terminal-rich-inline.test.ts src/terminal-string-width.test.ts tests/tui",
    "tui-corpus-check": "bun run scripts/tui-corpus-check.ts",
    "tui-fuzz": "bun run scripts/tui-fuzz.ts",
    "tui-oracle-check": "bun run scripts/tui-reference-check.ts",
    "tui-static-gate": "bun run scripts/tui-static-gate.ts",
    "terminal-demo": "bun run scripts/terminal-demo.ts",
    "terminal-demo-check": "bun run scripts/terminal-demo-check.ts",
    "terminal-feel-demo": "bun run scripts/terminal-feel-demo.ts",
    "terminal-feel-demo-check": "bun run scripts/terminal-feel-demo-check.ts",
    "typecheck:tui": "bunx tsc --noEmit -p tsconfig.tui.json",
    "typecheck:tui-validation": "bunx tsc --noEmit -p tsconfig.tui-validation.json"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.15.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "tsgolint": "^0.0.1",
    "typescript": "6.0.2",
    "wrap-ansi": "^10.0.0"
  }
}
