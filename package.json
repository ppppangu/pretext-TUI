{
  "name": "pretext-tui",
  "version": "0.0.0",
  "description": "Terminal-cell text layout primitives for TUI applications",
  "keywords": [
    "tui",
    "terminal",
    "terminal-ui",
    "terminal-layout",
    "line-breaking",
    "text-layout",
    "unicode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppppangu/pretext-TUI.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./terminal": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./terminal-rich-inline": {
      "types": "./dist/terminal-rich-inline.d.ts",
      "import": "./dist/terminal-rich-inline.js",
      "default": "./dist/terminal-rich-inline.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build:package": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "check": "bun run typecheck:tui && oxlint --type-aware src",
    "generate:bidi-data": "bun run scripts/generate-bidi-data.ts",
    "package-smoke-test": "bun run scripts/package-smoke-test.ts",
    "prepack": "bun run build:package",
    "prepublishOnly": "bun run check && bun run test:tui && bun run package-smoke-test",
    "test:tui": "bun test src/terminal-core.test.ts src/terminal-rich-inline.test.ts src/terminal-string-width.test.ts",
    "typecheck:tui": "bunx tsc --noEmit -p tsconfig.tui.json"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.15.0",
    "tsgolint": "^0.0.1",
    "typescript": "6.0.2"
  }
}
