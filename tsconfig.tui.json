// 补建说明：该配置为后续补建，用于建立纯 TUI TypeScript 边界；当前进度：Task 2 仅覆盖已无 DOM/Canvas 依赖的核心语义文件，待 measurement 重构后扩大到终端 API 与构建入口。
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": [],
    "allowJs": false,
    "noEmit": true
  },
  "files": [
    "src/analysis.ts",
    "src/bidi.ts",
    "src/generated/bidi-data.ts",
    "src/index.ts",
    "src/layout.ts",
    "src/line-break.ts",
    "src/line-text.ts",
    "src/measurement.ts",
    "src/terminal.ts",
    "src/terminal-rich-inline.ts",
    "src/ansi-tokenize.ts",
    "src/terminal-string-width.ts",
    "src/terminal-types.ts",
    "src/terminal-width-profile.ts"
  ],
  "include": [
    "src/index.ts",
    "src/terminal*.ts",
    "src/*terminal*.ts"
  ],
  "exclude": [
    "dist",
    "site",
    "pages",
    "scripts",
    "shared",
    "src/**/*.test.ts"
  ]
}
