        "lineTextGraphemeSegmentations": { "exact": 0 },
        "preparedGeometryBuilds": { "exact": 5 },
        "preparedGeometryCacheHits": { "max": 35 },
        "preparedGeometryGraphemes": { "max": 10 },
        "preparedGeometrySegments": { "max": 10 },
        "preparedGeometryWidthPrefixFallbacks": { "exact": 0 },
