{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "types": [],
    "rootDir": "./src",
    "outDir": "./dist/internal",
    "declaration": true
  },
  "include": [
    "src/analysis.ts",
    "src/bidi.ts",
    "src/generated/**/*.ts",
    "src/index.ts",
    "src/layout.ts",
    "src/line-break.ts",
    "src/line-text.ts",
    "src/measurement.ts",
    "src/terminal.ts",
    "src/terminal-cell-flow.ts",
    "src/terminal-line-index.ts",
    "src/terminal-materialize.ts",
    "src/terminal-page-cache.ts",
    "src/terminal-rich-inline.ts",
    "src/terminal-source-offset-index.ts",
    "src/ansi-tokenize.ts",
    "src/terminal-string-width.ts",
    "src/terminal-types.ts",
    "src/terminal-width-profile.ts",
    "src/text-modules.d.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
